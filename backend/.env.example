# Copy to `.env` on the server (never commit real secrets).
#
# Local dev: `backend/.env` is loaded automatically by python-dotenv from `manage.py`
# and `wsgi.py`. See the committed `backend/.env` template for DJANGO_DEBUG=True.
#
# Production: same `.env` path on the server, or systemd EnvironmentFile / docker env.

# --- Required on production server ---
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated hostnames (no scheme). Match your DNS / reverse proxy.
DJANGO_ALLOWED_HOSTS=afghanflags.com,www.afghanflags.com,api.afghanflags.com

# Extra CORS origins (comma-separated). Defaults already include https://afghanflags.com and api subdomain.
# Add staging or alternate frontends here only if needed.
DJANGO_CORS_ALLOWED_ORIGINS=

# Extra CSRF trusted origins (comma-separated full URLs with scheme).
DJANGO_CSRF_TRUSTED_ORIGINS=

# Set to 0 only if HTTPS is terminated elsewhere and you must not redirect HTTP (unusual).
DJANGO_SECURE_SSL_REDIRECT=1

# --- Local development (example) ---
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

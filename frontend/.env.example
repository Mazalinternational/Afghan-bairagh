# Copy to `.env` for local development (`npm start`).

# --- LOCAL (default) ---
REACT_APP_API_URL=http://localhost:8000

# --- PRODUCTION API (uncomment if needed) ---
# REACT_APP_API_URL=https://afghanflags.com
# REACT_APP_API_URL=https://www.afghanflags.com
# REACT_APP_API_URL=https://api.afghanflags.com

# Application Settings
REACT_APP_NAME=Afghan Flag Management System
REACT_APP_VERSION=1.0.0

# Optional: Enable/Disable Features
REACT_APP_ENABLE_AUTH=false
REACT_APP_ENABLE_DARK_MODE=true
